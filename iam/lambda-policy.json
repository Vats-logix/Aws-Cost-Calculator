{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ReadCostExplorer",
            "Effect": "Allow",
            "Action": "ce:GetCostAndUsage",
            "Resource": "*"
        },
        {
            "Sid": "WriteToSpecificS3",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetBucketLocation"
            ],
            "Resource": [
                "arn:aws:s3:::weekly-cost-report-storage-yogesh",
                "arn:aws:s3:::weekly-cost-report-storage-yogesh/*"
            ]
        },
        {
            "Sid": "NotifyViaSpecificSNS",
            "Effect": "Allow",
            "Action": "sns:Publish",
            "Resource": "arn:aws:sns:us-east-1:404870839722:BillingAlerts"
        }
    ]
}